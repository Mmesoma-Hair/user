# Base URL of the IdealCommerce backend API (public, read by the browser).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Base URL the Next.js server uses to reach the API (server-side: route handlers,
# RSC, middleware). In docker-compose this is the internal service name.
API_INTERNAL_BASE_URL=http://localhost:8000/api/v1

# Cloudinary cloud name for the custom next/image loader (Phase 3).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
